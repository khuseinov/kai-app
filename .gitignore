# ==============================================================================
# KAI App — Production-Grade Gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Flutter & Dart Builds
# ------------------------------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/

# Ignore generated Riverpod & Freezed files (compiled during build process / CI)
*.g.dart
*.freezed.dart

# Logs
flutter_*.log
*.log

# ------------------------------------------------------------------------------
# 2. Environment Configurations & Secrets
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------------------------------
# 3. Mobile Platform Configurations (iOS & Android)
# ------------------------------------------------------------------------------
# iOS
ios/Pods/
ios/.symlinks/
ios/Flutter/App.framework
ios/Flutter/Flutter.podspec
ios/Flutter/engine/
ios/Flutter/flutter_export_environment.sh
ios/ServiceDefinitions.json
ios/Runner/GeneratedPluginRegistrant.*
*.xcworkspace/
!ios/Runner.xcworkspace/

# Android
android/.gradle/
android/app/debug/
android/app/profile/
android/app/release/
android/local.properties
android/gradle.properties
*.jks
*.keystore

# ------------------------------------------------------------------------------
# 4. Committed Assets (Whitelisted Exceptions)
# ------------------------------------------------------------------------------
# Whitelist compiled PNG master brand assets
!brand/*.png
!web/og-default.png
!web/favicon.png
!web/favicon-16.png

# Whitelist platform launcher/splash assets
!ios/Runner/Assets.xcassets/**/*.png
!android/app/src/main/res/**/*.png

# Whitelist golden-file test assets
!test/features/boot/goldens/*.png

# ------------------------------------------------------------------------------
# 5. IDEs & Editors
# ------------------------------------------------------------------------------
# Android Studio / IntelliJ IDEA
.idea/
*.iml

# VS Code / Cursor
.vscode/

# macOS / Xcode user settings
*.mode1v3
*.mode2v3
*.normal
*.perspectivev3
xcuserdata/

# ------------------------------------------------------------------------------
# 6. Operating System Files
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------------------------
# 7. Agent & Local Tooling
# ------------------------------------------------------------------------------
.claude/
.claire/
.playwright-mcp/
.worktrees/
/*.png
new-design/*.png
