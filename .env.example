API_BASE_URL=https://<username>-<space>.hf.space
USE_REAL_CHAT=true
# Required when the HF Space is private. Generate at https://huggingface.co/settings/tokens
HF_TOKEN=
# Used by backend admin/health endpoints (/sessions, /user, /health).
INTERNAL_HEALTH_TOKEN=
# Voice gateway base URL and API key (required for voice input/output).
VOICE_GATEWAY_BASE_URL=http://localhost:8002
VOICE_GATEWAY_API_KEY=
